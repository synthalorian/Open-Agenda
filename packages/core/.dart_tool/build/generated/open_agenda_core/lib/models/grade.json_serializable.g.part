_$AssignmentImpl _$$AssignmentImplFromJson(Map<String, dynamic> json) =>
    _$AssignmentImpl(
      id: json['id'] as String,
      title: json['title'] as String,
      subject: json['subject'] as String,
      dueDate: DateTime.parse(json['dueDate'] as String),
      totalPoints: (json['totalPoints'] as num).toDouble(),
      category: $enumDecode(_$AssignmentCategoryEnumMap, json['category']),
      description: json['description'] as String?,
      createdAt: DateTime.parse(json['createdAt'] as String),
    );

Map<String, dynamic> _$$AssignmentImplToJson(_$AssignmentImpl instance) =>
    <String, dynamic>{
      'id': instance.id,
      'title': instance.title,
      'subject': instance.subject,
      'dueDate': instance.dueDate.toIso8601String(),
      'totalPoints': instance.totalPoints,
      'category': _$AssignmentCategoryEnumMap[instance.category]!,
      'description': instance.description,
      'createdAt': instance.createdAt.toIso8601String(),
    };

const _$AssignmentCategoryEnumMap = {
  AssignmentCategory.homework: 'homework',
  AssignmentCategory.quiz: 'quiz',
  AssignmentCategory.test: 'test',
  AssignmentCategory.project: 'project',
  AssignmentCategory.participation: 'participation',
};

